# 本项目是 GitHub Pages 静态前端。
# 前端只能填写 Supabase Project URL 和 Publishable Key。
# 禁止把 SUPABASE_SERVICE_ROLE_KEY、SUPABASE_SECRET_KEY 提交到 GitHub。

SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# 下面这些只允许配置在 Supabase Edge Functions 的 server secrets 中，不要放进前端 JS。
SUPABASE_SERVICE_ROLE_KEY=do-not-commit-this
CLAIM_TOKEN_SECRET=do-not-commit-this

BIRTHDAY_PRIVATE_BUCKET=birthday-order-private
BIRTHDAY_PUBLISHED_BUCKET=birthday-published-assets
GITHUB_PAGES_URL=https://mengm919.github.io/birthday-intake-system/
